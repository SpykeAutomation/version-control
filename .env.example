# Copy to .env for local development. In production set these as real
# environment variables / secrets on your host (Render, droplet, etc.).

# Where the SQLite DB and per-project Git repos are stored. Use an absolute
# path on a persistent volume in production (e.g. /data).
PLCVC_DATA_DIR=./data

# Secret used to sign JWTs. MUST be long and random in production (>=32 bytes).
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
PLCVC_JWT_SECRET=dev-insecure-change-me

# How long a login stays valid, in minutes (default: 1 week).
PLCVC_JWT_EXPIRE_MINUTES=10080

# Allowed browser origins for the frontend. "*" is fine for a pilot; set it to
# your frontend URL (e.g. https://app.example.com) before launch.
PLCVC_CORS_ORIGINS=*
