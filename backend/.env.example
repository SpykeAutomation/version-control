# Copy to .env. Docker Compose auto-loads this file; for local uvicorn dev the
# app reads the PLCVC_* values directly.

# ---- App settings (read by the FastAPI app; prefix PLCVC_) ----

# Where the SQLite DB and per-project Git repos live. Used directly when running
# locally with uvicorn. Under docker-compose the app always uses /data inside
# the container (set in docker-compose.yml); see PLCVC_HOST_DATA_DIR below.
PLCVC_DATA_DIR=./data

# Secret used to sign JWTs. MUST be long and random in production (>=32 bytes).
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
PLCVC_JWT_SECRET=dev-insecure-change-me

# How long a login stays valid, in minutes (default: 1 week).
PLCVC_JWT_EXPIRE_MINUTES=10080

# Allowed browser origins. "*" is fine locally; in production set this to your
# frontend, e.g. https://app.spykeautomation.com
PLCVC_CORS_ORIGINS=*

# Per-IP login rate limit: a coarse flood guard, set high on purpose — a whole
# site behind one corporate NAT shares a single client IP, so this must clear a
# plant's worth of shift-start logins.
PLCVC_LOGIN_RATE_MAX=600
PLCVC_LOGIN_RATE_WINDOW_SECONDS=60

# Per-account lockout (the real anti-brute-force control): this many *failed*
# attempts on one email within the window locks that account's logins until
# the window rolls; a successful login clears it.
PLCVC_LOGIN_ACCOUNT_MAX=8
PLCVC_LOGIN_ACCOUNT_WINDOW_SECONDS=900

# Invite rate limit (anti-enumeration): max preview/accept calls on the public
# /invites/{token} endpoints per client IP per window.
PLCVC_INVITE_RATE_MAX=20
PLCVC_INVITE_RATE_WINDOW_SECONDS=60

# Member-candidate search rate limit (anti-enumeration): max add-member
# searches per *account* per window — the endpoint substring-matches the org's
# user directory, so it stays tight; a human typing stays well under it.
PLCVC_MEMBER_SEARCH_RATE_MAX=30
PLCVC_MEMBER_SEARCH_RATE_WINDOW_SECONDS=60

# Max size of a single uploaded file, in megabytes (enforced per file; a 413 is
# returned for anything larger). The Caddy edge separately caps the whole
# request body (Caddyfile `request_body max_size`) — keep that >= a batch of
# these so multi-file uploads aren't blocked at the proxy.
PLCVC_MAX_UPLOAD_MB=100

# Per-organization storage cap, in gigabytes. Counts the logical bytes of
# committed uploads (maintained counters, not a disk walk); a commit upload
# that would exceed it returns 507. Per-org overrides live on the org row.
PLCVC_ORG_STORAGE_LIMIT_GB=2

# Soft cap on the whole diff cache, in megabytes. When exceeded, the least
# recently used cached diffs are evicted (a diff is cheap to recompute lazily).
PLCVC_DIFF_CACHE_MAX_MB=500

# ---- Deployment settings (read by docker-compose.yml / Caddy) ----

# Public hostname Caddy serves and obtains a TLS certificate for.
DOMAIN=api.spykeautomation.com

# Host path holding the persistent data (Git repos + SQLite), bind-mounted to
# /data in the api container. On the server use an absolute path outside the
# repo clone, e.g. /opt/plc-vcs/data
PLCVC_HOST_DATA_DIR=./data
