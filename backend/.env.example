# Copy to .env. Docker Compose auto-loads this file; for local uvicorn dev the
# app reads the PLCVC_* values directly.

# ---- App settings (read by the FastAPI app; prefix PLCVC_) ----

# Where the SQLite DB and per-project Git repos live. Used directly when running
# locally with uvicorn. Under docker-compose the app always uses /data inside
# the container (set in docker-compose.yml); see PLCVC_HOST_DATA_DIR below.
PLCVC_DATA_DIR=./data

# Secret used to sign JWTs. MUST be long and random in production (>=32 bytes).
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
PLCVC_JWT_SECRET=dev-insecure-change-me

# How long a login stays valid, in minutes (default: 1 week).
PLCVC_JWT_EXPIRE_MINUTES=10080

# Allowed browser origins. "*" is fine locally; in production set this to your
# frontend, e.g. https://app.spykeautomation.com
PLCVC_CORS_ORIGINS=*

# Login rate limit (anti-brute-force): max attempts per client IP per window.
PLCVC_LOGIN_RATE_MAX=10
PLCVC_LOGIN_RATE_WINDOW_SECONDS=60

# Invite rate limit (anti-enumeration): max preview/accept calls on the public
# /invites/{token} endpoints per client IP per window.
PLCVC_INVITE_RATE_MAX=20
PLCVC_INVITE_RATE_WINDOW_SECONDS=60

# ---- Deployment settings (read by docker-compose.yml / Caddy) ----

# Public hostname Caddy serves and obtains a TLS certificate for.
DOMAIN=api.spykeautomation.com

# Host path holding the persistent data (Git repos + SQLite), bind-mounted to
# /data in the api container. On the droplet use an absolute path outside the
# repo clone, e.g. /opt/plc-vcs/data
PLCVC_HOST_DATA_DIR=./data
