# Copy to .env.local for local dev.

# Where the UI sends API calls. Leave EMPTY in dev: the client then makes
# same-origin relative requests, which the Vite dev server proxies to the
# backend (default target: the hosted api.spykeautomation.com). See
# vite.config.ts. Only set this to an absolute URL if you're not using the
# dev proxy.
VITE_API_URL=

# Backend the dev proxy forwards to. Defaults to the hosted API. Set to
# http://localhost:8000 to test against a backend running on your machine
# (run it with PLCVC_CORS_ORIGINS=http://localhost:5173).
VITE_PROXY_TARGET=https://api.spykeautomation.com
