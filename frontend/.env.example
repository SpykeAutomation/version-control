# Copy to .env.local for local dev. The backend origin the UI talks to.
# Matches the dev CORS origin documented in backend/README.md.
VITE_API_URL=http://localhost:8000

# Demo mode: set to 1 to click through every screen with NO backend running.
# Auth and project-create calls return canned data instead of hitting the API.
# Leave unset (or 0) to talk to a real backend.
VITE_DEMO=0
